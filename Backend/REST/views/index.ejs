<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quora Posts</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <h1>Quora Posts</h1>
    <% for(post of posts){ %>
        <div class="post">
            <h2 class="user">@<%= post.username %></h2>
            <p class="caption"><%= post.caption %></p>
            <a href="http://localhost:8080/posts/<%= post.id %>">see in detail</a>&nbsp;&nbsp;&nbsp;
            <a href="http://localhost:8080/posts/<%= post.id %>/edit">Edit</a>&nbsp;&nbsp;&nbsp;
            <form method="post" action="/posts/<%=post.id%>?_method=DELETE">
                <button>Delete</button>
            </form>
        </div>
    <% } %><br>
    <a href="http://localhost:8080/posts/new"><b>Create New Post</b></a>
</body>
</html>